---
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  bgColor?: 'white' | 'neutral';
}

const { id, title, subtitle, bgColor = 'white' } = Astro.props;

const bgClass = bgColor === 'neutral' ? 'bg-neutral-50' : 'bg-white';
---

<section id={id} class:list={[bgClass, 'py-16 sm:py-20 lg:py-24']}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      (title || subtitle) && (
        <div class="text-center mb-12 sm:mb-16">
          {title && <h2 class="text-3xl sm:text-4xl font-semibold text-neutral-900 mb-4">{title}</h2>}
          {subtitle && <p class="text-lg text-neutral-600">{subtitle}</p>}
        </div>
      )
    }

    <slot />
  </div>
</section>
