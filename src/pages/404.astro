---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Page Not Found">
  <div class="min-h-[calc(100vh-12rem)] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <h1 class="text-6xl font-semibold text-neutral-900 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-neutral-900 mb-3">Page Not Found</h2>
      <p class="text-neutral-600 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-3 bg-neutral-900 text-white rounded-lg font-medium hover:bg-neutral-800 transition-colors"
      >
        Back to Home
      </a>
    </div>
  </div>
</MainLayout>
