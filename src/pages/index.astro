---
import MainLayout from '../layouts/MainLayout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import { siteConfig } from '../config';
---

<MainLayout title="Home">
  <!-- Hero Section -->
  <SectionWrapper bgColor="white">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-neutral-900 mb-6">
        {siteConfig.tagline}
      </h1>
      <p class="text-lg sm:text-xl text-neutral-600 mb-8">
        {siteConfig.description}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#contact"
          class="px-6 py-3 bg-neutral-900 text-white rounded-lg font-medium hover:bg-neutral-800 transition-colors text-center"
        >
          Get Started
        </a>
        <a
          href="#about"
          class="px-6 py-3 border border-neutral-300 text-neutral-900 rounded-lg font-medium hover:border-neutral-400 transition-colors text-center"
        >
          Learn More
        </a>
      </div>
    </div>
  </SectionWrapper>

  <!-- About Section -->
  <SectionWrapper
    id="about"
    title="About"
    subtitle="Learn who we are and what we do"
    bgColor="neutral"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h3 class="text-xl font-semibold text-neutral-900 mb-4">Our Story</h3>
        <p class="text-neutral-600 mb-4">
          This is where you tell your company's story. Share your mission, values, and
          what makes you unique.
        </p>
        <p class="text-neutral-600">
          Keep it concise and focused on what matters to your customers.
        </p>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-neutral-900 mb-4">Why Choose Us</h3>
        <ul class="space-y-3 text-neutral-600">
          <li class="flex gap-3">
            <span class="text-neutral-400">✓</span>
            <span>Professional and reliable service</span>
          </li>
          <li class="flex gap-3">
            <span class="text-neutral-400">✓</span>
            <span>Customer-focused approach</span>
          </li>
          <li class="flex gap-3">
            <span class="text-neutral-400">✓</span>
            <span>Years of proven experience</span>
          </li>
        </ul>
      </div>
    </div>
  </SectionWrapper>

  <!-- Services Section -->
  <SectionWrapper
    id="services"
    title="Services"
    subtitle="What we offer"
    bgColor="white"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        [
          {
            title: 'Service One',
            description: 'Brief description of your first service or offering.',
          },
          {
            title: 'Service Two',
            description: 'Brief description of your second service or offering.',
          },
          {
            title: 'Service Three',
            description: 'Brief description of your third service or offering.',
          },
        ].map((service) => (
          <div class="p-6 border border-neutral-200 rounded-lg hover:border-neutral-300 transition-colors">
            <h3 class="text-lg font-semibold text-neutral-900 mb-3">{service.title}</h3>
            <p class="text-neutral-600">{service.description}</p>
          </div>
        ))
      }
    </div>
  </SectionWrapper>

  <!-- Contact Section -->
  <SectionWrapper
    id="contact"
    title="Get In Touch"
    subtitle="We'd love to hear from you"
    bgColor="neutral"
  >
    <div class="max-w-2xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-8">
        <div class="text-center">
          <p class="text-neutral-600 mb-2">Email</p>
          <a
            href={`mailto:${siteConfig.email}`}
            class="text-lg font-semibold text-neutral-900 hover:text-neutral-700"
          >
            {siteConfig.email}
          </a>
        </div>

        <div class="text-center">
          <p class="text-neutral-600 mb-2">Phone</p>
          <a
            href={`tel:${siteConfig.phone}`}
            class="text-lg font-semibold text-neutral-900 hover:text-neutral-700"
          >
            {siteConfig.phone}
          </a>
        </div>
      </div>

      <div class="text-center">
        <p class="text-neutral-600 mb-4">{siteConfig.address}</p>
        <p class="text-neutral-600">
          We typically respond to inquiries within 24 hours during business days.
        </p>
      </div>
    </div>
  </SectionWrapper>
</MainLayout>
