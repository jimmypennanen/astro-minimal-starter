---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title}` : 'Home';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
